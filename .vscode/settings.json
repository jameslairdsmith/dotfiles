{
  "nix.formatterPath": [
    "alejandra"
  ],
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide",
    "editor.formatOnSave": true
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": [
          "alejandra"
        ], // or nixfmt or nixpkgs-fmt
      }
    }
  }
}