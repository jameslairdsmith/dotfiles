[
	{
		"key": "ctrl+shift+alt+o",
		"command": "workbench.action.quickOpen"
	},
	{
		"key": "ctrl+shift+alt+q",
		"command": "workbench.action.quickchat.toggle",
		"when": "chatIsEnabled"
	},
	{
		"key": "ctrl+l",
		"command": "workbench.action.terminal.clear"
	},
	{
		"key": "ctrl+shift+m",
		"command": "workbench.action.terminal.sendSequence",
		"when": "terminalFocus",
		"args": {
			"text": " |>"
		}
	},
		{
		"key": "ctrl+l",
		"command": "workbench.action.terminal.sendSequence",
		"when": "terminalFocus && terminalFocusInAny",
		"args": {
			//"text": "shell(\"clear\")\n"
			"text": "cat(c('\\033[2J','\\033[0;0H'))\n"
		}
	},
	// Don't run Ctrl+L while in editor
	{
		"key": "ctrl+l",
		"command": null,
		"when": "editorTextFocus"
	},
	{
		"key": "ctrl+shift+m",
		"command": "editor.action.insertSnippet",
		"when": "editorTextFocus && editorLangId == 'r'",
		"args": {
			"snippet": " |>$0"
		}
	},
	{
		"key": "ctrl+alt+shift+l",
		"command": "workbench.action.terminal.sendSequence",
		"when": "editorTextFocus && editorLangId == 'r'",
		"args": {
			"text": "devtools::load_all()\n"
		}
	},
		{
		"key": "ctrl+alt+shift+l",
		"command": "workbench.action.terminal.sendSequence",
		"when": "terminalFocus && terminalFocusInAny",
		"args": {
			"text": "devtools::load_all()\n"
		}
	},
	{
		"key": "ctrl+shift+alt+l",
		"command": "jupyter.runFileInteractive",
		"when": "editorTextFocus && !inDebugMode && editorLangId == 'python'"
	},
	{
		"key": "ctrl+l",
		"command": "jupyter.interactive.clearAllCells",
		"when": "editorTextFocus && !inDebugMode && editorLangId == 'python'"
	}
]