# Worktrunk shell integration
if command -v wt >/dev/null 2>&1; then
  eval "$(command wt config shell init zsh)"
  eval "$(declare -f wt | sed '1s/wt/__wt_orig/')"
  wt() {
    if [ "$1" = "remove" ]; then
      shift
      __wt_orig remove --no-delete-branch "$@"
    else
      __wt_orig "$@"
    fi
  }
fi
